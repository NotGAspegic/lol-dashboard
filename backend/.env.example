# Get your dev key from developer.riotgames.com
RIOT_API_KEY=RGAPI-your-key-goes-here

# Docker Compose defaults
DATABASE_URL=postgresql+asyncpg://loluser:lolpassword@postgres:5432/loldb
REDIS_URL=redis://redis:6379/0
FRONTEND_ORIGIN=http://localhost:3000
# Comma-separated origins are also supported:
# FRONTEND_ORIGIN=http://localhost:3000,https://farsight-gg.vercel.app


RIOT_REGION=europe
RIOT_PLATFORM=euw1


POSTGRES_DB=lol_db
POSTGRES_USER=lol_user
POSTGRES_PASSWORD=lol_password
